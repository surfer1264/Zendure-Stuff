#!/usr/bin/env python3
"""
Zendure - Logger + Web-Dashboard in einem.

Pollt das Gerät regelmaessig, speichert die Daten in CSV und SQLite
und stellt unter http://localhost:8080 ein Live-Dashboard bereit.

Kein CORS-Problem, weil Browser und Daten vom selben Server kommen.

Start:   python3 zendure_dashboard.py
Aufruf:  http://localhost:8080   (im Browser)

https://bodo-schoenfeld.de/installation-von-python-unter-windows-11/
Keine externen Pakete noetig - nur Python 3 Standardbibliothek.
"""
import json, sqlite3, csv, time, os, threading, urllib.request
from datetime import datetime
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

# ----------------------------- Konfiguration -----------------------------
DEVICE_URL = "http://YOURIP/properties/report"
POLL_INTERVAL = 30          # Sekunden zwischen Abfragen
WEB_PORT = 8080
CSV_FILE = "zendure_log.csv"
DB_FILE = "zendure_log.db"

PROPS = [
    "electricLevel", "packInputPower", "outputPackPower", "outputHomePower",
    "gridInputPower", "solarInputPower", "solarPower1", "solarPower2",
    "solarPower3", "solarPower4", "remainOutTime", "packState",
    "hyperTmp", "BatVolt", "outputLimit", "inputLimit", "socSet",
    "minSoc", "acMode", "rssi", "is_error",
]

# Letzter abgerufener Datensatz (vom Poll-Thread gefuellt, vom Webserver gelesen)
_latest = {"data": None, "ts": 0, "error": None}
_lock = threading.Lock()


# ----------------------------- Datenbank ----------------------------------
def setup_db():
    con = sqlite3.connect(DB_FILE, check_same_thread=False)
    cols = ", ".join(f"{p} REAL" for p in PROPS)
    con.execute(f"CREATE TABLE IF NOT EXISTS device (ts INTEGER PRIMARY KEY, dt TEXT, {cols})")
    con.execute("""CREATE TABLE IF NOT EXISTS packs (
        ts INTEGER, dt TEXT, sn TEXT, socLevel REAL, state INTEGER,
        power REAL, maxTemp REAL, totalVol REAL, batcur INTEGER,
        maxVol INTEGER, minVol INTEGER)""")
    con.commit()
    return con


def fetch_device():
    req = urllib.request.Request(DEVICE_URL, headers={"Accept": "application/json"})
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read().decode())


def log_csv(ts, dt, props):
    new = not os.path.exists(CSV_FILE)
    with open(CSV_FILE, "a", newline="") as f:
        w = csv.writer(f)
        if new:
            w.writerow(["ts", "dt"] + PROPS)
        w.writerow([ts, dt] + [props.get(p, "") for p in PROPS])


def store(con, data):
    ts = data.get("timestamp", int(time.time()))
    dt = datetime.now().isoformat(timespec="seconds")
    props = data.get("properties", {})

    placeholders = ", ".join("?" * (len(PROPS) + 2))
    con.execute(f"INSERT OR REPLACE INTO device VALUES ({placeholders})",
                [ts, dt] + [props.get(p) for p in PROPS])
    for pk in data.get("packData", []):
        con.execute("INSERT INTO packs VALUES (?,?,?,?,?,?,?,?,?,?,?)",
                    [ts, dt, pk.get("sn"), pk.get("socLevel"), pk.get("state"),
                     pk.get("power"), pk.get("maxTemp"), pk.get("totalVol"),
                     pk.get("batcur"), pk.get("maxVol"), pk.get("minVol")])
    con.commit()
    log_csv(ts, dt, props)


# ----------------------------- Poll-Thread --------------------------------
def poll_loop():
    con = setup_db()
    print(f"Logging {DEVICE_URL} alle {POLL_INTERVAL}s -> {CSV_FILE} + {DB_FILE}")
    while True:
        try:
            data = fetch_device()
            store(con, data)
            with _lock:
                _latest.update(data=data, ts=time.time(), error=None)
            p = data.get("properties", {})
            print(f"{datetime.now():%H:%M:%S}  SoC={p.get('electricLevel')}%  "
                  f"Solar={p.get('solarInputPower')}W  Out={p.get('outputHomePower')}W")
        except Exception as e:
            with _lock:
                _latest.update(error=str(e))
            print(f"{datetime.now():%H:%M:%S}  Fehler: {e}")
        time.sleep(POLL_INTERVAL)


# ----------------------------- Webserver ----------------------------------
class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a):
        pass  # ruhige Konsole

    def _send(self, code, body, ctype="application/json"):
        b = body.encode() if isinstance(body, str) else body
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(b)))
        self.end_headers()
        self.wfile.write(b)

    def do_GET(self):
        if self.path == "/" or self.path.startswith("/index"):
            self._send(200, PAGE, "text/html; charset=utf-8")
        elif self.path == "/data":
            with _lock:
                payload = {"data": _latest["data"], "ts": _latest["ts"],
                           "error": _latest["error"]}
            self._send(200, json.dumps(payload))
        elif self.path == "/history":
            con = sqlite3.connect(DB_FILE)
            rows = con.execute(
                "SELECT dt, electricLevel, solarInputPower, outputHomePower "
                "FROM device ORDER BY ts DESC LIMIT 200").fetchall()
            con.close()
            rows.reverse()
            self._send(200, json.dumps(rows))
        else:
            self._send(404, "not found", "text/plain")


